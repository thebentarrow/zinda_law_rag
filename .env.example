# OpenAI / LLM
OPENAI_API_KEY=sk-...

# Chat model used for answer generation, guardrail classification, and structural re-ranking
CHAT_MODEL=gpt-4o-mini
CHAT_TEMPERATURE=0.2
CHAT_MAX_TOKENS=1024

# Embedding model used for FAQ indexing, document chunk indexing, and query embedding
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# RAG -- number of chunks retrieved and passed to the synthesis LLM
RETRIEVAL_TOP_K=2

# Database
# Path inside the container / on the host (mounted volume)
SQLITE_PATH=/data/app.db
CHROMA_PATH=/data/chroma

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost
